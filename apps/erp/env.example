# Configuração do Banco de Dados PostgreSQL
POSTGRES_USER=erp
POSTGRES_PASSWORD=senha123
POSTGRES_DB=erpdb
POSTGRES_PORT=5432

# Configuração do Backend
DATABASE_URL=postgresql://erp:senha123@localhost:5432/erpdb
JWT_SECRET=super-segredo-alterar-em-producao    
JWT_EXPIRES_IN=7d
# RH / espelho / “banco até hoje”: use o fuso da operação. Em VPS com UTC, sem TZ o “hoje”
# atrasa e dias úteis futuros podem aparecer como falta no mês aberto.
TZ=America/Sao_Paulo

# ─── Armazenamento de arquivos (uploads) ─────────────────────────────────────
# Dados de negócio ficam no PostgreSQL. Arquivos (fotos de ponto, anexos de tarefas,
# imagens de estoque, etc.) são gravados em disco no BACKEND, sob UPLOADS_DIR.
# O Nest expõe esses arquivos em UPLOADS_URL_PREFIX (padrão /uploads) com express.static.
# Alguns tipos sensíveis (ponto, docs RH, afastamentos) são servidos em /uploads-protegido/...
# com JWT — mas continuam no mesmo diretório raiz (subpastas ponto/, docs-rh/, etc.).
#
# Desenvolvimento local (sem Docker): deixe vazio ou use caminho relativo ao cwd do backend.
UPLOADS_DIR=./uploads
UPLOADS_URL_PREFIX=/uploads
#
# Docker Compose: o serviço backend já define UPLOADS_DIR=/app/uploads e monta o volume.
# Em Windows/macOS, troque em docker-compose.yml "/var/erp-uploads" por ex. "./uploads:/app/uploads"
# para não depender de pasta Linux no host.
#
# Upload — padrão 2048 MB (2 GB) por arquivo em todo o ERP (multer + body parser).
# UPLOAD_MAX_MB=2048
# Overrides por perfil (opcional; só se divergir do global):
# UPLOAD_DESCRICAO_PROJETO_MAX_MB=2048
# UPLOAD_TAREFA_MAX_MB=2048
# UPLOAD_GENERIC_MAX_MB=2048
# UPLOAD_TREINAMENTO_MAX_MB=2048
# UPLOAD_MAX_FILES_PER_REQUEST=20

# Web Push (notificações no sistema: Android Chrome, desktop; iOS Safari costuma exigir PWA instalada)
# Gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Ex.: mailto:suporte@suaempresa.com.br
VAPID_SUBJECT=mailto:no-reply@example.com
# Docker/produção: 3001. Dev local: 3000
BACKEND_PORT=3001
NODE_ENV=production

# ─── Segurança ───────────────────────────────────────────────────────────────
# CORS: domínios permitidos em produção (separados por vírgula).
# Em desenvolvimento, qualquer origem é aceita automaticamente.
# Exemplo VPS: CORS_ORIGINS=https://erp.alenxandriaglobaltec.com
CORS_ORIGINS=https://erp.alenxandriaglobaltec.com

# Configuração do Frontend (build: usado no Docker)
# VPS com domínio (PC + celular): deixe vazio e use Nginx com proxy /api (deploy/nginx-erp.conf e deploy/VPS-ACESSO-MOBILE.md).
# Docker/local: use URL do backend (http://localhost:3000 ou http://localhost:3001).
VITE_API_URL=
FRONTEND_PORT=5174
# Limites no browser (espelhe o backend; padrão 2 GB).
# VITE_UPLOAD_MAX_MB=2048
# VITE_UPLOAD_DESCRICAO_PROJETO_MAX_MB=2048
# VITE_UPLOAD_TAREFA_MAX_MB=2048
# VITE_UPLOAD_GENERIC_MAX_MB=2048
# VITE_UPLOAD_TREINAMENTO_MAX_MB=2048

# ─── Backup semanal (VPS) — ver deploy/BACKUP-VPS.md ────────────────────────
# ERP_BACKUP_DIR=/var/backups/erp
# ERP_UPLOADS_DIR=/var/erp-uploads
# ERP_BACKUP_RETAIN_WEEKS=8