# Copie para .env e preencha com valores reais:
#   cp .env.example .env
#
# O arquivo .env NAO vai para o GitHub.

# --- MariaDB (container db) ---
MYSQL_DATABASE=moodle
MYSQL_USER=moodle
MYSQL_PASSWORD=troque_senha_forte_aqui
MYSQL_ROOT_PASSWORD=troque_senha_root_forte_aqui

# --- Moodle (container moodle / config.php) ---
MOODLE_DB_HOST=db
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodle
MOODLE_DB_PASSWORD=troque_senha_forte_aqui
MOODLE_WWWROOT=https://ava.alenxandriaglobaltec.com
MOODLE_DATAROOT=/var/moodledata

# --- Docker ---
MOODLE_HTTP_PORT=8081
