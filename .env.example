# G.One Suite Completa + Teca.ia — arquivo pronto para rodar.
# Para teste local, pode usar como está. Para produção, altere domínios, e-mail e TODAS as senhas.

# Domínios de produção. Aponte estes subdomínios para o IP da VPS antes de iniciar em produção.
GONE_DOMAIN=one.seudominio.com.br
ERP_DOMAIN=erp.seudominio.com.br
AVA_DOMAIN=ava.seudominio.com.br
TECA_DOMAIN=teca.seudominio.com.br
LETSENCRYPT_EMAIL=seu-email@seudominio.com.br

TZ=America/Sao_Paulo

# ERP / PostgreSQL
ERP_POSTGRES_USER=erp
ERP_POSTGRES_PASSWORD=troque_por_senha_forte_erp
ERP_POSTGRES_DB=erpdb
ERP_JWT_SECRET=troque_por_um_segredo_grande_com_64_caracteres_erp
ERP_JWT_EXPIRES_IN=7d
UPLOAD_MAX_MB=2048
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:no-reply@seudominio.com.br

# AVA / Moodle / MariaDB
AVA_MYSQL_DATABASE=moodle
AVA_MYSQL_USER=moodle
AVA_MYSQL_PASSWORD=troque_por_senha_forte_moodle
AVA_MYSQL_ROOT_PASSWORD=troque_por_senha_root_moodle

# TECA.IA / PostgreSQL + API HTTP + ponte para IA TCP/Gemini
TECA_POSTGRES_USER=teca
TECA_POSTGRES_PASSWORD=troque_por_senha_forte_teca
TECA_POSTGRES_DB=tecadb
TECA_JWT_SECRET=troque_por_um_segredo_teca_com_64_caracteres
TECA_JWT_EXPIRES_IN=7d
TECA_ADMIN_EMAIL=admin@teca.local
TECA_ADMIN_PASSWORD=admin123456
TECA_ADMIN_NAME=Administrador TECA

# Servidor de IA original da TECA. Se estiver rodando em outro servidor/rede, habilite e informe host/porta.
TECA_TCP_ENABLED=false
TECA_IA_HOST=
TECA_IA_PORT=6000
TECA_TCP_TIMEOUT_MS=120000

# Fallback online da TECA quando o servidor TCP não estiver disponível. Opcional.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
